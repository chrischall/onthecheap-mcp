{
  "name": "charlotteonthecheap-mcp",
  "version": "0.0.0",
  "mcpName": "io.github.chrischall/charlotteonthecheap-mcp",
  "description": "Charlotte On The Cheap MCP server for Claude — developed and maintained by AI (Claude Code)",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/charlotteonthecheap-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "charlotte",
    "events",
    "local-events",
    "free-events",
    "deals"
  ],
  "type": "module",
  "bin": {
    "charlotteonthecheap-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills/",
    ".mcp.json",
    "server.json"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --external:dotenv --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chrischall/mcp-utils": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.0",
    "node-html-parser": "^9.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.2"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
